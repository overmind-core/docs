{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Overmind",
  "theme": "luma",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#ed670f",
    "light": "#f69a5b",
    "dark": "#ed670f"
  },
  "background": {
    "color": {
      "light": "#fdf6ec",
      "dark": "#120b06"
    },
    "decoration": "grid"
  },
  "fonts": {
    "heading": {
      "family": "PP Mondwest",
      "source": "/fonts/PPMondwest-Regular.woff2",
      "format": "woff2",
      "weight": 400
    },
    "body": {
      "family": "PP Neue Montreal",
      "source": "/fonts/PPNeueMontreal-Book.woff2",
      "format": "woff2",
      "weight": 400
    }
  },
  "styling": {
    "eyebrows": "section",
    "codeblocks": "system"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Console",
      "href": "https://console.overmindlab.ai"
    }
  },
  "navigation": {
    "groups": [
      {
        "group": "Overview",
        "pages": [
          "index"
        ]
      },
      {
        "group": "Onboarding and Integrations",
        "pages": [
          "onboarding/onboarding",
          "onboarding/integrations",
          "onboarding/tracing",
          "onboarding/instrumentation"
        ]
      },
      {
        "group": "Context",
        "pages": [
          "context/repositories",
          "context/agents",
          "context/datasets-and-traces"
        ]
      },
      {
        "group": "Evaluation",
        "pages": [
          "evaluation/eval-metrics",
          "evaluation/optimizers"
        ]
      },
      {
        "group": "Fine-tuning",
        "pages": [
          "fine-tuning"
        ]
      },
      {
        "group": "Inference",
        "pages": [
          "inference"
        ]
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "cursor"
    ]
  }
}
